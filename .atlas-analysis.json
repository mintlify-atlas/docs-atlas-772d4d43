  "keyFeatures": [
    "Privacy-first analytics with hashed user identifiers",
    "Simple signal-based API with TelemetryDeck.signal()",
    "Automatic session tracking with foreground/background detection",
    "SwiftUI view modifier for navigation tracking",
    "StoreKit integration for purchase and trial tracking",
    "AARRR pirate metrics presets (Acquisition, Activation, Referral, Revenue)",
    "Duration signal tracking for measuring time on task",
    "Custom metadata enrichers for adding dynamic signal parameters",
    "Support for iOS, macOS, watchOS, tvOS, and visionOS",
    "Configurable logging and custom server support"
  ],
  "publicApiSurface": [
